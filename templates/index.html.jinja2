<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🐟 渔业文献每周速览 — Fishery Papers Weekly Digest</title>
<style>
/* ===== CSS Variables ===== */
:root {
  --bg: #f7fafc;
  --bg-card: #ffffff;
  --text: #2d3748;
  --text-secondary: #718096;
  --text-muted: #a0aec0;
  --border: #e2e8f0;
  --primary: #2b6cb0;
  --primary-light: #bee3f8;
  --primary-dark: #1a365d;
  --accent: #e76f51;
  --accent-light: #fed7d7;
  --teal: #319795;
  --teal-light: #b2f5ea;
  --gold: #d69e2e;
  --gold-light: #fefcbf;
  --shadow: 0 2px 8px rgba(0,0,0,0.06);
  --shadow-hover: 0 8px 24px rgba(0,0,0,0.10);
  --radius: 12px;
  --radius-sm: 8px;
}
[data-theme="dark"] {
  --bg: #1a202c;
  --bg-card: #2d3748;
  --text: #e2e8f0;
  --text-secondary: #a0aec0;
  --text-muted: #718096;
  --border: #4a5568;
  --primary: #90cdf4;
  --primary-light: #2a4365;
  --primary-dark: #bee3f8;
  --accent: #fc8181;
  --accent-light: #742a2a;
  --teal: #81e6d9;
  --teal-light: #234e52;
  --gold: #f6e05e;
  --gold-light: #3d3a1a;
  --shadow: 0 2px 8px rgba(0,0,0,0.3);
  --shadow-hover: 0 8px 24px rgba(0,0,0,0.5);
}

/* ===== Reset ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  transition: background 0.3s, color 0.3s;
}
a { color: var(--primary); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ===== Header ===== */
.header {
  background: linear-gradient(135deg, #1a365d 0%, #2b6cb0 50%, #319795 100%);
  color: #fff;
  padding: 2.5rem 1.5rem 2rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.header::before {
  content: "";
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.header h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.02em; position: relative; }
.header h1 .fish { display: inline-block; animation: swim 2s ease-in-out infinite; }
@keyframes swim {
  0%,100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(3px) rotate(-3deg); }
  75% { transform: translateX(-3px) rotate(3deg); }
}
.header p { margin-top: 0.5rem; opacity: 0.9; font-size: 1.05rem; position: relative; }
.header .update-time { margin-top: 0.75rem; font-size: 0.85rem; opacity: 0.7; position: relative; }

/* ===== Container ===== */
.container { max-width: 1100px; margin: 0 auto; padding: 1.5rem; }

/* ===== Stats ===== */
.stats-bar { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.stat-card {
  flex: 1; min-width: 140px;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 1rem 1.25rem;
  text-align: center; box-shadow: var(--shadow);
}
.stat-card .number { font-size: 2rem; font-weight: 800; color: var(--primary); }
.stat-card .label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem; }

/* ===== Controls ===== */
.controls {
  display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;
  margin-bottom: 1.5rem; padding: 1rem 1.25rem;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius); box-shadow: var(--shadow);
}
.search-box { flex: 1; min-width: 200px; position: relative; }
.search-box input {
  width: 100%; padding: 0.65rem 1rem 0.65rem 2.5rem;
  border: 2px solid var(--border); border-radius: var(--radius-sm);
  font-size: 0.95rem; background: var(--bg); color: var(--text);
  transition: border-color 0.2s;
}
.search-box input:focus { outline: none; border-color: var(--primary); }
.search-box .search-icon {
  position: absolute; left: 0.85rem; top: 50%;
  transform: translateY(-50%); color: var(--text-muted); pointer-events: none;
}
.theme-toggle {
  padding: 0.65rem 1rem; border: 2px solid var(--border);
  border-radius: var(--radius-sm); background: var(--bg);
  color: var(--text); cursor: pointer; font-size: 0.9rem;
  transition: all 0.2s; white-space: nowrap;
}
.theme-toggle:hover { border-color: var(--primary); }

/* ===== Week Section ===== */
.week-section {
  margin-bottom: 1.25rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  transition: box-shadow 0.25s;
}
.week-section:hover { box-shadow: var(--shadow-hover); }

.week-header {
  display: flex; align-items: center; gap: 1rem;
  padding: 1.25rem 1.5rem;
  cursor: pointer;
  user-select: none;
  transition: background 0.2s;
  flex-wrap: wrap;
}
.week-header:hover { background: var(--bg); }
.week-header .week-icon {
  font-size: 2rem; flex-shrink: 0;
  transition: transform 0.3s;
}
.week-section.open .week-header .week-icon { transform: rotate(180deg); }
.week-header .week-info { flex: 1; min-width: 0; }
.week-header .week-range {
  font-size: 0.85rem; color: var(--text-muted);
  font-weight: 500;
}
.week-header .week-topic {
  font-size: 1.15rem; font-weight: 700;
  color: var(--primary-dark);
  margin-top: 0.15rem;
  line-height: 1.4;
}
.week-header .week-badge {
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0.5rem 1rem;
  background: var(--primary-light);
  color: var(--primary-dark);
  border-radius: 20px;
  font-size: 0.9rem; font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

.week-body { display: none; padding: 0 1.5rem 1.5rem; }
.week-section.open .week-body { display: block; }

/* ===== Paper Cards ===== */
.paper-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 0.85rem;
}
.paper-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1.1rem;
  transition: all 0.25s;
  display: flex; flex-direction: column;
  position: relative;
}
.paper-card:hover {
  box-shadow: var(--shadow-hover);
  transform: translateY(-1px);
  border-color: var(--primary-light);
}
.paper-card .source-badge {
  position: absolute; top: 0.6rem; right: 0.6rem;
  font-size: 0.65rem; padding: 0.12rem 0.45rem;
  border-radius: 10px;
  background: var(--teal-light); color: var(--teal);
  font-weight: 600; text-transform: uppercase;
}
.paper-card .journal {
  font-size: 0.78rem; color: var(--teal); font-weight: 600;
  margin-bottom: 0.3rem; letter-spacing: 0.02em;
}
.paper-card .title {
  font-size: 0.95rem; font-weight: 700; line-height: 1.45;
  margin-bottom: 0.35rem;
}
.paper-card .title a { color: var(--text); }
.paper-card .title a:hover { color: var(--primary); text-decoration: none; }
.paper-card .meta {
  font-size: 0.78rem; color: var(--text-muted);
  margin-bottom: 0.6rem;
  display: flex; flex-wrap: wrap; gap: 0.5rem;
}
.paper-card .meta span { display: inline-flex; align-items: center; gap: 0.2rem; }

/* Chinese Summary — the star of the show */
.paper-card .summary-cn {
  background: linear-gradient(135deg, #fffaf0, #fffff0);
  border-left: 3px solid var(--gold);
  padding: 0.75rem 0.9rem;
  margin-bottom: 0.5rem;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 0.9rem; line-height: 1.6;
  color: #744210;
}
[data-theme="dark"] .paper-card .summary-cn {
  background: linear-gradient(135deg, #3d2e1a, #372a10);
  color: #fbd38d;
}

/* Abstract toggle */
.abstract-toggle {
  font-size: 0.8rem; color: var(--primary); cursor: pointer;
  font-weight: 600; user-select: none;
  display: inline-flex; align-items: center; gap: 0.25rem;
  padding: 0.3rem 0; border: none; background: none;
}
.abstract-toggle:hover { color: var(--accent); }
.abstract-toggle .arrow {
  display: inline-block; transition: transform 0.2s; font-size: 0.7rem;
}
.abstract-toggle.open .arrow { transform: rotate(90deg); }
.abstract-content {
  display: none;
  font-size: 0.82rem; color: var(--text-secondary); line-height: 1.55;
  padding: 0.5rem 0; border-top: 1px dashed var(--border); margin-top: 0.4rem;
}
.abstract-content.visible { display: block; }

/* ===== Hidden / No Results ===== */
.paper-card.hidden { display: none; }
.no-results {
  display: none; text-align: center; padding: 3rem;
  color: var(--text-muted); font-size: 1.1rem;
}
.no-results.visible { display: block; }

/* ===== Footer ===== */
.footer {
  text-align: center; padding: 2rem 1.5rem;
  color: var(--text-muted); font-size: 0.85rem;
  border-top: 1px solid var(--border); margin-top: 2rem;
}
.footer a { color: var(--text-secondary); }
.footer .heart { color: var(--accent); }

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .header h1 { font-size: 1.4rem; }
  .paper-grid { grid-template-columns: 1fr; }
  .week-header { padding: 1rem; gap: 0.5rem; }
  .week-header .week-topic { font-size: 1rem; }
  .stats-bar { gap: 0.5rem; }
  .stat-card { min-width: 70px; padding: 0.6rem; }
  .stat-card .number { font-size: 1.3rem; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.week-section { animation: fadeIn 0.4s ease-out; }
</style>
</head>
<body>

<header class="header">
  <h1><span class="fish">🐟</span> 渔业文献每周速览</h1>
  <p>Fisheries Science Weekly Digest — AI 驱动的学术前沿速递</p>
  <div class="update-time">📅 更新于 {{ update_time }}</div>
</header>

<div class="container">

  <!-- Stats -->
  <div class="stats-bar">
    <div class="stat-card">
      <div class="number">{{ total_papers }}</div>
      <div class="label">📄 文献总数</div>
    </div>
    <div class="stat-card">
      <div class="number">{{ week_count }}</div>
      <div class="label">📅 覆盖周数</div>
    </div>
    <div class="stat-card">
      <div class="number">{{ summary_count }}</div>
      <div class="label">🤖 AI 已总结</div>
    </div>
    <div class="stat-card">
      <div class="number">{{ journal_count }}</div>
      <div class="label">📚 期刊来源</div>
    </div>
  </div>

  <!-- Controls -->
  <div class="controls">
    <div class="search-box">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="搜索标题、作者、期刊、摘要..." oninput="filterPapers()">
    </div>
    <button class="theme-toggle" onclick="toggleTheme()">
      <span id="themeIcon">🌙</span> <span id="themeLabel">暗色模式</span>
    </button>
  </div>

  <div class="no-results" id="noResults">
    <p>😕 没有匹配的论文，请尝试其他搜索词</p>
  </div>

  <!-- Weekly Sections -->
  {% for week in weeks %}
  <div class="week-section open" id="week-{{ week.week_key }}">
    <div class="week-header" onclick="toggleWeek('week-{{ week.week_key }}')">
      <div class="week-icon">📅</div>
      <div class="week-info">
        <div class="week-range">{{ week.week_range }}</div>
        <div class="week-topic">📌 {{ week.topic }}</div>
      </div>
      <div class="week-badge">
        <span>📄</span> {{ week.papers|length }} 篇
      </div>
    </div>
    <div class="week-body">
      <div class="paper-grid">
        {% for paper in week.papers %}
        <div class="paper-card"
             data-title="{{ paper.title|lower }}"
             data-authors="{{ paper.authors|lower }}"
             data-journal="{{ paper.journal|lower }}"
             data-abstract="{{ paper.abstract|lower }}"
             data-summary="{{ paper.summary_cn|lower }}"
             data-week="{{ week.week_key }}">
          <span class="source-badge">{{ paper.source[:8] }}</span>

          {% if paper.journal %}
          <div class="journal">📰 {{ paper.journal }}</div>
          {% endif %}

          <!-- 中文总结优先展示 -->
          {% if paper.summary_cn and not paper.summary_cn.startswith('[') %}
          <div class="summary-cn">💡 {{ paper.summary_cn }}</div>
          {% endif %}

          <div class="title">
            <a href="{{ paper.url }}" target="_blank" rel="noopener">{{ paper.title }}</a>
          </div>

          <div class="meta">
            {% if paper.authors %}
            <span>👤 {{ paper.authors[:60] }}{% if paper.authors|length > 60 %}...{% endif %}</span>
            {% endif %}
            <span>📅 {{ paper.date }}</span>
          </div>

          {% if paper.abstract %}
          <button class="abstract-toggle" onclick="toggleAbstract(this)" aria-expanded="false">
            <span class="arrow">▶</span> 查看英文摘要
          </button>
          <div class="abstract-content">{{ paper.abstract }}</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endfor %}

  {% if not weeks %}
  <div style="text-align:center;padding:4rem 2rem;color:var(--text-muted)">
    <div style="font-size:4rem;margin-bottom:1rem">📭</div>
    <h2>暂无文献</h2>
    <p>请先运行 fetch_papers.py 获取最新论文数据</p>
  </div>
  {% endif %}

</div>

<footer class="footer">
  <p>由 <span class="heart">❤️</span> <a href="https://claude.ai" target="_blank">Claude AI</a> 驱动 |
  数据来源：<a href="https://crossref.org" target="_blank">Crossref</a>、<a href="https://www.semanticscholar.org/" target="_blank">Semantic Scholar</a> |
  覆盖 Nature / Science / PNAS 及其子刊</p>
</footer>

<script>
// Theme
function toggleTheme() {
  const html = document.documentElement;
  const icon = document.getElementById('themeIcon');
  const label = document.getElementById('themeLabel');
  const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  icon.textContent = next === 'dark' ? '☀️' : '🌙';
  label.textContent = next === 'dark' ? '亮色模式' : '暗色模式';
  localStorage.setItem('theme', next);
}
(function() {
  const saved = localStorage.getItem('theme');
  if (saved) {
    document.documentElement.setAttribute('data-theme', saved);
    document.getElementById('themeIcon').textContent = saved === 'dark' ? '☀️' : '🌙';
    document.getElementById('themeLabel').textContent = saved === 'dark' ? '亮色模式' : '暗色模式';
  }
})();

// Toggle week section
function toggleWeek(id) {
  document.getElementById(id).classList.toggle('open');
}

// Toggle abstract
function toggleAbstract(btn) {
  const content = btn.nextElementSibling;
  const visible = content.classList.contains('visible');
  content.classList.toggle('visible');
  btn.classList.toggle('open');
  btn.querySelector('.arrow').textContent = visible ? '▶' : '▼';
  btn.setAttribute('aria-expanded', !visible);
}

// Search
function filterPapers() {
  const query = (document.getElementById('searchInput').value || '').toLowerCase().trim();
  const cards = document.querySelectorAll('.paper-card');
  let visibleTotal = 0;

  cards.forEach(card => {
    let show = true;
    if (query) {
      const text = [
        card.getAttribute('data-title') || '',
        card.getAttribute('data-authors') || '',
        card.getAttribute('data-journal') || '',
        card.getAttribute('data-abstract') || '',
        card.getAttribute('data-summary') || '',
      ].join(' ');
      show = text.includes(query);
    }
    card.classList.toggle('hidden', !show);
    if (show) visibleTotal++;
  });

  // Show/hide week sections
  document.querySelectorAll('.week-section').forEach(section => {
    const visible = section.querySelectorAll('.paper-card:not(.hidden)');
    section.style.display = visible.length > 0 ? '' : 'none';
    // Auto-expand weeks with matches
    if (query && visible.length > 0) section.classList.add('open');
  });

  document.getElementById('noResults').classList.toggle('visible', visibleTotal === 0);
}
</script>

</body>
</html>
